<?xml version="1.0"?>
<ruleset name="PaySentinel">
    <description>PHP CodeSniffer configuration for PaySentinel WordPress plugin</description>

    <!-- Use WordPress coding standards -->
    <rule ref="WordPress">
        <!-- Exclude some rules that are too strict for this project -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>
    </rule>

    <!-- Add PHPCompatibility for cross-version PHP compatibility -->
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP">
        <include-pattern>*.php</include-pattern>
    </rule>

    <!-- Add VariableAnalysis for better variable checking -->
    <rule ref="VariableAnalysis">
        <include-pattern>*.php</include-pattern>
    </rule>

    <!-- Exclude vendor directory -->
    <exclude-pattern>vendor/*</exclude-pattern>

    <!-- Exclude test files from some rules -->
    <rule ref="WordPress.Files.FileName">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <!-- Set PHP version compatibility -->
    <config name="testVersion" value="7.4-"/>

    <!-- Register WooCommerce capability used throughout the plugin -->
    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="manage_woocommerce"/>
            </property>
        </properties>
    </rule>

    <!-- Files to check -->
    <file>paysentinel.php</file>
    <file>includes/</file>
    <file>tests/</file>
</ruleset>