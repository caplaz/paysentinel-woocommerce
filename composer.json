{
  "name": "paysentinel/plugin",
  "description": "PaySentinel - Payment Monitor for WooCommerce Plugin",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "yoast/phpunit-polyfills": "^1.0",
    "lucatume/wp-browser": "^4.5",
    "squizlabs/php_codesniffer": "^3.7",
    "phpmd/phpmd": "^2.13",
    "wp-coding-standards/wpcs": "^3.0",
    "phpstan/phpstan": "^2.1",
    "php-stubs/wordpress-stubs": "^6.0",
    "phpcompatibility/php-compatibility": "^9.3",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "sirbrillig/phpcs-variable-analysis": "^2.11",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "onepix/woocommerce-stubs": "^9.7"
  },
  "autoload": {
    "psr-4": {
      "PaySentinel\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PaySentinel\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "lint": "phpcs",
    "lint-fix": "phpcbf",
    "mess-detector": "phpmd includes/,paysentinel.php text phpmd.xml",
    "static-analysis": "phpstan analyse --memory-limit=1G",
    "quality": [
      "@lint",
      "@mess-detector",
      "@static-analysis"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
