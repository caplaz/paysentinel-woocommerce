{
  "name": "wc-payment-monitor/plugin",
  "description": "WooCommerce Payment Monitor Plugin",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "yoast/phpunit-polyfills": "^1.0",
    "lucatume/wp-browser": "^4.5",
    "squizlabs/php_codesniffer": "^3.7",
    "phpmd/phpmd": "^2.13",
    "wp-coding-standards/wpcs": "^3.0",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "WC_Payment_Monitor\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WC_Payment_Monitor\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "lint": "phpcs",
    "lint-fix": "phpcbf",
    "mess-detector": "phpmd includes/,wc-payment-monitor.php text phpmd.xml",
    "static-analysis": "phpstan analyse --memory-limit=256M",
    "quality": [
      "@lint",
      "@mess-detector",
      "@static-analysis"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
