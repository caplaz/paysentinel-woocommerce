{
  "name": "wc-payment-monitor/plugin",
  "description": "WooCommerce Payment Monitor Plugin",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "yoast/phpunit-polyfills": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "WC_Payment_Monitor\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WC_Payment_Monitor\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage"
  }
}
